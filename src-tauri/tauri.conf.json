{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mini-Term",
  "version": "0.2.4",
  "identifier": "com.tauri-app.tauri-app",
  "build": {
    "beforeDevCommand": "node scripts/ensure-vite-dev.mjs",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mini-Term",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../docs/AGENT_POLICY_PROMPTS.md",
      "../docs/MCP.md",
      "../docs/MCP_SETUP.md",
      "../docs/skills/**/*",
      "../scripts/install-mini-term-skills.ps1"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
